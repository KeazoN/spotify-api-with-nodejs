<%- include('inc/header') %>

<div class="container">
	<div class="cards">
		<div class="card">
			<div class="image">
				<img src=<%= user.images[0].url %>>
			</div>
			<div class="name display">
				<h1><%- user.display_name %></h1>
			</div>
			<div class="description">
				<h3>Followers: <strong><%- user.followers.total %></strong></h3>
			</div>
			<div class="music-cards">
				<% playlist.items.forEach((index) => { %>
					<div class="all-cards">
						<a href="/playlist/<%- index.id %>">
						<div class="music-card">
							<div class="left">
								<div class="number"><%- index.popularity %></div>
								<div class="music-image"><img src=<%= index.images[0].url %>></div>
								<div class="music-name-artist">
									<h3><%- index.name%></h3>
									<h5><%- index.owner.display_name%></h5>
								</div>
							</div>
							<div class="right">
								<div class="time">
									<p><%- index.tracks.total %></p>
								</div>
							</div>
						</div>
					</a>
					</div>
				<% }); %>
			</div>
		</div>
	</div>
</div>
<%- include('inc/footer') %>