    <div class="spotify-login-img">
      <img src="img/login-wallpaper.png">
    </div>
    <div class="sidebar">
      <div class="sidebar-header">
        <i class="fab fa-spotify"></i>
      </div>
      <div class="sidebar-center">
        <form action="/login">
          <button type="submit"><i class="fab fa-spotify"></i> Login Spotify</button>
