      <div class="sidebar-footer">
        <p>It does not have any partnership or contract with Spotify. <a href="https://github.com/keazon/spotify-api-nodejs">It is open source.</a></p>
      </div>
    </div>
  </div>
</div>

<%- include('inc/footer') %>
